<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="1700" author="dr6">
        <createTable tableName="stain_type">
            <column name="id" type="INT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="name" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="enabled" type="BOOLEAN" defaultValue="TRUE">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated" type="TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="1701" author="dr6">
        <createTable tableName="stain">
            <column name="operation_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_stain_operation" referencedTableName="operation" referencedColumnNames="id" primaryKey="true"/>
            </column>
            <column name="stain_type_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_stain_stain_type" referencedTableName="stain_type" referencedColumnNames="id"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="1702" author="dr6">
        <dropNotNullConstraint tableName="measurement" columnName="sample_id" columnDataType="INT"/>
        <dropNotNullConstraint tableName="measurement" columnName="slot_id" columnDataType="INT"/>
    </changeSet>

    <changeSet id="1750" author="dr6">
        <insert tableName="operation_type">
            <column name="name" value="Stain"/>
            <column name="flags" value="9"/>
        </insert>
    </changeSet>

    <changeSet id="1751" author="dr6">
        <insert tableName="stain_type">
            <column name="name" value="H&amp;E"/>
        </insert>
        <insert tableName="stain_type">
            <column name="name" value="Masson's Trichrome"/>
        </insert>
    </changeSet>

</databaseChangeLog>
